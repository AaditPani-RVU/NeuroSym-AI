{
  "version": "v1",
  "name": "injection-v1",
  "description": "Core prompt injection detection presets derived from PAIR, DAN, GCG, Perez et al. 2022, Garak corpus",
  "presets": {
    "ignore_instructions": [
      "ignore\\s+(all\\s+)?(previous|prior|above|earlier)\\s+(instructions?|rules?|prompts?|context)",
      "disregard\\s+(all\\s+)?(previous|prior|above)\\s+(instructions?|rules?|prompts?)",
      "forget\\s+(everything|all|your\\s+instructions?|your\\s+rules?)",
      "override\\s+(your\\s+)?(instructions?|rules?|guidelines?|programming)",
      "your\\s+(new|real|true|actual)\\s+instructions?\\s+(are|is)",
      "from\\s+now\\s+on\\s+(you\\s+will|you\\s+are|ignore)"
    ],
    "role_switch": [
      "\\bact\\s+as\\s+(?:an?\\s+)?(dan|jailbroken|evil|unrestricted|unfiltered|uncensored)",
      "\\bpretend\\s+(?:you\\s+are|to\\s+be)\\s+(?:an?\\s+)?(dan|evil|unrestricted|hacker|attacker)",
      "\\byou\\s+are\\s+now\\s+(?:an?\\s+)?(dan|jailbroken|unrestricted|evil|chaos\\s*gpt|uncensored|unfiltered)",
      "\\bswitch\\s+(?:to|into)\\s+(developer|god|sudo|jailbreak|evil)\\s+mode",
      "\\benable\\s+(developer|jailbreak|unrestricted|evil|chaos)\\s+mode",
      "\\bdan\\s+mode\\s+(enabled|on|activated)",
      "you\\s+have\\s+no\\s+(restrictions?|rules?|guidelines?|limits?|ethics?)"
    ],
    "system_prompt_extraction": [
      "(repeat|print|output|tell\\s+me|show\\s+me|reveal|expose|leak)\\s+(your|the)\\s+system\\s+prompt",
      "(repeat|print|output|reveal)\\s+(your|the)\\s+(initial|original|full|entire)\\s+(instructions?|prompt|context)",
      "what\\s+(are|were)\\s+your\\s+(original|initial|secret|hidden)\\s+instructions?",
      "(print|output|repeat)\\s+everything\\s+(above|before\\s+this|in\\s+your\\s+context)",
      "(show|display|output)\\s+your\\s+(full\\s+)?conversation\\s+history"
    ],
    "delimiter_injection": [
      "---\\s*(new\\s+)?(instruction|system|prompt|task|command)",
      "###\\s*(new\\s+)?(instruction|system|prompt|task|command)",
      "\\[\\s*(system|instruction|override|new\\s+task)\\s*\\]",
      "<\\s*(system|instruction|override|prompt)\\s*>",
      "````+\\s*(system|instruction|override)",
      "\\/\\*\\s*(system|instruction|override|new\\s+task)"
    ],
    "indirect_injection": [
      "(translate|summarize|process|analyze)\\s+(this|the\\s+following)\\s+(and\\s+then|then)\\s+(delete|run|execute|send)",
      "the\\s+(document|file|url|page|text)\\s+(says?|instructs?|tells?\\s+you)\\s+to",
      "embedded\\s+instructions?",
      "hidden\\s+(command|instruction|payload|message)"
    ],
    "system_commands": [
      "\\brm\\s+-rf\\b",
      "\\bdel(ete)?\\s+/[sfq]",
      "\\bformat\\s+[cde]:\\\\",
      "\\bshutdown\\s+(/s|/r|/h|/f)",
      "\\bkill\\s+(-9|-SIGKILL)\\b",
      "\\b(drop|truncate)\\s+(table|database|schema)\\b",
      "\\bos\\.system\\s*\\(",
      "\\bsubprocess\\.(run|call|Popen)\\s*\\(",
      "\\beval\\s*\\(",
      "\\bexec\\s*\\("
    ],
    "path_traversal": [
      "\\.\\.[/\\\\]{1,2}",
      "%2e%2e[%2f%5c]",
      "(C:\\\\Windows|C:\\\\System32|/etc/passwd|/etc/shadow|/proc/)",
      "\\$env:(PATH|COMPUTERNAME|USERNAME|USERPROFILE|APPDATA)",
      "~(/.ssh|/.aws|/.gnupg)"
    ],
    "obfuscation": [
      "base64\\s*(decode|decoded|encoded)?\\s*[:=]",
      "rot13\\s*[:=]",
      "hex\\s*(decode|encoded)?\\s*[:=]",
      "[\u0456\u0456]\\s*[gG]\\s*[nN]\\s*[oO]\\s*[rR]\\s*[eE]",
      "\\u0000",
      "\\\\x[0-9a-fA-F]{2}(\\\\x[0-9a-fA-F]{2})+"
    ],
    "exfiltration": [
      "(send|email|post|upload|exfiltrate)\\s+(?:\\w+\\s+){0,4}(passwords?|credentials?|keys?|secrets?|tokens?|files?|data)\\b",
      "(send|email)\\s+(?:\\w+\\s+){0,3}to\\s+\\S+@\\S+",
      "(http|ftp|smtp)s?://\\S+\\s*(password|token|key|secret|credential)",
      "curl\\s+.*\\s+-d\\s+",
      "wget\\s+.*\\s+--post-data",
      "nc\\s+-[luve]"
    ]
  }
}